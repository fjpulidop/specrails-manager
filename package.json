{
  "name": "specrails-hub",
  "version": "1.21.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fjpulidop/specrails-hub.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "specrails-hub": "cli/dist/specrails-hub.js"
  },
  "files": [
    "cli/dist",
    "server/dist",
    "client/dist",
    "docs"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "cd client && npm run dev",
    "build:server": "rm -rf server/dist && tsc --project tsconfig.json",
    "build:cli": "tsc --project tsconfig.cli.json",
    "build": "npm run build:server && cd client && npm run build && cd .. && npm run build:cli",
    "typecheck": "tsc --noEmit && cd client && tsc --noEmit",
    "check-core-compat": "tsx scripts/check-core-compat.ts",
    "test": "vitest run && tsx scripts/check-core-compat.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:client": "cd client && npx vitest run",
    "test:all": "vitest run && cd client && npx vitest run"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "express": "^5.2.1",
    "tree-kill": "^1.2.2",
    "uuid": "^13.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/chokidar": "^2.1.7",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.2.1",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  }
}
