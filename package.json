{
  "name": "specrails-hub",
  "version": "0.1.0",
  "bin": {
    "specrails-hub": "./cli/dist/specrails-hub.js"
  },
  "files": [
    "cli/dist",
    "server/dist",
    "client/dist"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "cd client && npm run dev",
    "build:server": "rm -rf server/dist && tsc --project tsconfig.json",
    "build:cli": "tsc --project tsconfig.cli.json",
    "build": "npm run build:server && cd client && npm run build && cd .. && npm run build:cli",
    "typecheck": "tsc --noEmit && cd client && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:client": "cd client && npx vitest run",
    "test:all": "vitest run && cd client && npx vitest run"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "better-sqlite3": "^12.8.0",
    "express": "^4.18.0",
    "tree-kill": "^1.2.2",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^2.0.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.0",
    "concurrently": "^8.2.0",
    "supertest": "^6.3.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
