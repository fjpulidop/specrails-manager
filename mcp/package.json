{
  "name": "@specrails/hub-mcp",
  "version": "1.0.0",
  "description": "MCP server that exposes specrails-hub to Claude Desktop and any MCP-compatible client",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "specrails-hub-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run --config tests/vitest.config.ts",
    "test:watch": "vitest --config tests/vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.1",
    "zod": "^3.24.2"
  },
  "peerDependencies": {
    "better-sqlite3": ">=11.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "engines": {
    "node": ">=20"
  }
}
